{
  "name": "autom-rh-v2",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20.11" },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "db:generate": "pnpm --filter @rh/db generate",
    "db:migrate": "pnpm --filter @rh/db migrate",
    "db:seed": "pnpm --filter @rh/db seed",
    "db:verify": "pnpm --filter @rh/db verify"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
