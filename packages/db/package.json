{
  "name": "@rh/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --env-file=../../.env ../../node_modules/vitest/vitest.mjs run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env scripts/migrate.ts",
    "seed": "tsx --env-file=../../.env scripts/seed-prompts.ts",
    "seed:test": "tsx --env-file=../../.env scripts/seed-test-data.ts",
    "verify": "tsx --env-file=../../.env scripts/verify-counts.ts"
  },
  "dependencies": {
    "@rh/config": "workspace:*",
    "@rh/types": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
