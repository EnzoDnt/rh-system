    "pg-boss": "^10.1.5",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "jose": "^5.9.6",
    "unpdf": "^0.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
