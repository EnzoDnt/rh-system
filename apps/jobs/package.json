    "@rh/db": "workspace:*",
    "@rh/types": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg-boss": "^10.1.5",
    "resend": "^4.0.1",
    "unpdf": "^0.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
