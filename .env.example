# --- Supabase (obligatoire) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# --- Anthropic (obligatoire) ---
ANTHROPIC_API_KEY=

# --- Email Resend (optionnel — laisser vide pour utiliser le flow mailto par défaut) ---
# Sans RESEND_API_KEY, le recruteur envoie depuis son propre client mail (Gmail, Outlook…)
# via le bouton "Ouvrir dans mon mail" dans le dashboard.
# Avec RESEND_API_KEY, un bouton "Envoyer via Resend" apparaît pour l'envoi automatique.
RESEND_API_KEY=
RESEND_FROM=L'équipe Recrutement <recrutement@your-domain.example>

# --- Apify pour scraping LinkedIn (optionnel) ---
# Si défini, le worker scrape les profils LinkedIn pour enrichir le scoring.
# Coût Apify : environ 0.05€ par candidature.
# Sans cette clé, Claude score très bien avec le CV + réponses formulaire seulement.
APIFY_API_KEY=

# --- Notifications externes (optionnelles — les alertes sont dans /notifications par défaut) ---
# Par défaut toutes les alertes worker sont stockées en BD et visibles dans le dashboard /notifications.
# Pour recevoir des push externes EN PLUS du dashboard :
# Topic ntfy.sh (gratuit, pas de compte, choisis un nom unguessable)
NTFY_TOPIC=
# OU Slack webhook (override ntfy si défini)
SLACK_WEBHOOK_URL=

# --- URLs publiques (remplir avec tes vrais domaines) ---
PUBLIC_API_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_FICHES_URL=http://localhost:3000/fiches

# --- Branding (optionnel, défaut "Recrutement") ---
# BRAND_NAME est consommée par le backend (worker) :
#   - signature des emails et fallback du champ "From" Resend
#   - notifications externes (Slack/ntfy)
#   - substitution du placeholder <Votre Marque> dans les prompts IA seed
BRAND_NAME=Recrutement
# Override l'expéditeur Resend (sinon construit depuis BRAND_NAME)
BRAND_FROM_EMAIL=

# --- Pour le frontend (build-time, préfixe VITE_) ---
# Ces vars sont bakées au build du web. Les changer = rebuild nécessaire.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3000

# Branding côté frontend (toutes optionnelles, défaut "Recrutement" + thème par défaut)
# IMPORTANT : entoure de guillemets toute valeur qui commence par '#' (hex CSS),
# sinon le parseur dotenv interprète le reste comme un commentaire.
VITE_BRAND_NAME=Recrutement
VITE_BRAND_PRIMARY_COLOR=
VITE_BRAND_PRIMARY_COLOR_HOVER=
# Exemple : VITE_BRAND_PRIMARY_COLOR="#1f6feb"
VITE_BRAND_LOGO_URL=
